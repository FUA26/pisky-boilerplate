{
  "extends": "@workspace/typescript-config/nextjs.json",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "@/*": ["./*"],
      "@workspace/hooks": ["../../packages/hooks/src/index.ts"],
      "@workspace/hooks/*": ["../../packages/hooks/src/*"],
      "@workspace/types": ["../../packages/types/src/index.ts"],
      "@workspace/types/*": ["../../packages/types/src/*"],
      "@workspace/ui/*": ["../../packages/ui/src/*"],
      "@/features/*": ["./features/*"],
      "@/features/auth/*": ["./features/auth/*"]
    },
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    "next.config.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": ["node_modules"]
}
