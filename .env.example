# Database
DATABASE_URL="postgresql://user:password@localhost:5432/zilpo_admin?schema=public"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-generate-with-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"

# AWS S3 / MinIO (for file uploads)
S3_BUCKET="zilpo-uploads"
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID="your-access-key-id"
AWS_SECRET_ACCESS_KEY="your-secret-access-key"

# For MinIO (local development) - uncomment to use MinIO instead of S3
# MINIO_ENDPOINT="http://localhost:9000"

# CDN URL (optional, for public file access)
# CDN_URL="https://cdn.yourdomain.com"
