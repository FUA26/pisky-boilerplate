# docker-compose.env
# Infrastructure credentials for local development

# Postgres
POSTGRES_USER=naiera_user
POSTGRES_PASSWORD=dev_password_change_me
POSTGRES_DB=naiera_db

# Redis
REDIS_PASSWORD=dev_redis_password_change_me

# MinIO
MINIO_ROOT_USER=minio_admin
MINIO_ROOT_PASSWORD=dev_minio_password_change_me

# pgAdmin
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=dev_pgadmin_password_change_me

# MinIO Console
MINIO_CONSOLE_URL=http://localhost:8401
